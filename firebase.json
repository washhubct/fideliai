{
    "hosting": {
        "public": ".",
        "ignore": [
            "firebase.json",
            "firestore.rules",
            "firestore.indexes.json",
            "functions/**",
            "**/.*",
            "**/node_modules/**"
        ],
        "rewrites": [
            {
                "source": "**",
                "destination": "/index.html"
            }
        ]
    },
    "functions": {
        "source": "functions",
        "runtime": "nodejs22"
    }
}